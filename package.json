{
  "name": "sunrise",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Personal goal-achievement tracker (pluginable, zero-runtime-deps)",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --format=iife --target=es2022 --sourcemap --outfile=dist/sunrise.js && node scripts/gen-sw.mjs",
    "deploy": "bash scripts/deploy-pages.sh",
    "typecheck": "tsc --noEmit",
    "test": "node --test \"test/**/*.test.ts\"",
    "lint": "eslint src test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  }
}
